# Copy this file to .env.preview and fill in your project values

# Firebase Web App configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# App Check and reCAPTCHA configuration
VITE_RECAPTCHA_V3_SITE_KEY=your_captcha_site_key_here
VITE_APPCHECK_DEBUG=true  # Set to true to enable App Check debug mode
VITE_APPCHECK_DEBUG_TOKEN=your_app_check_debug_token_here

# Firebase CLI configuration
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_TOKEN=your_firebase_token_here
